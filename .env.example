# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TELEGRAM_BOT_TOKEN: Used by the secure Cloudflare backend/server to validate Telegram auth
TELEGRAM_BOT_TOKEN="8628933356:AAHJpX7FI4OMBZfMaB-pc4q9uwO0NLW3Ps0"

# VITE_API_URL: (Optional) The URL of your API backend handling secure referrals.
# If you deploy to Cloudflare Pages via GitHub, you can leave this blank because the Page Functions run on the same domain.
VITE_API_URL=""
