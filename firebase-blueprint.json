{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the Telegram Mini App",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "points": { "type": "number" },
        "referralsCount": { "type": "number" },
        "invitedBy": { "type": ["string", "null"] },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "points", "referralsCount", "createdAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Records that a user was invited by an inviter",
      "type": "object",
      "properties": {
        "inviterId": { "type": "string" },
        "invitedId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["inviterId", "invitedId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles indexed by their Telegram ID"
    },
    "/referrals/{referralId}": {
      "schema": { "$ref": "#/entities/Referral" },
      "description": "Referral logs indexed by inviterId_invitedId"
    }
  }
}
