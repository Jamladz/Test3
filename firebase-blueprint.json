{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a Telegram Mini App user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Telegram user ID." },
        "authUid": { "type": "string", "description": "Firebase Auth UID." },
        "points": { "type": "integer" },
        "tonBalance": { "type": "number" },
        "referralsCount": { "type": "integer" },
        "invitedBy": { "type": ["string", "null"] },
        "createdAt": { "type": "string" },
        "completedTasks": { "type": "array", "items": { "type": "string" } },
        "lastAdDate": { "type": "string" },
        "adsWatched": { "type": "integer" },
        "lastWheelDate": { "type": "string" },
        "lastWheelAdDate": { "type": "string" },
        "wheelAdsWatched": { "type": "integer" },
        "adSpinsCount": { "type": "integer" }
      },
      "required": ["userId", "authUid", "points", "tonBalance", "referralsCount", "createdAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Represents a referral relationship.",
      "type": "object",
      "properties": {
        "inviterId": { "type": "string" },
        "invitedId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["inviterId", "invitedId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Stores successful referrals."
    }
  }
}
