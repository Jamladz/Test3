rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isAdmin() {
      // Allow if they are in the admins collection (console added)
      // or if their role is admin
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // User Schema Validation
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'balance', 'energy', 'lastLogin']) 
        && data.balance is number 
        && data.energy is number 
        && data.lastLogin is number;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());

      // Update rules (Anti-Cheat logic)
      allow update: if (isOwner(userId) && isValidUser(incoming()) && (
        // Action: standard sync (balance increases, energy decreases/regenerates)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'energy', 'lastLogin', 'offlineEarnings', 'friendsCount', 'adsWatched', 'referredBy', 'referralRewardClaimed', 'upgrades', 'missions', 'totalTapped', 'gifts', 'createdAt', 'tonBalance', 'tonMiningRate', 'lastTonSync', 'tonMiningActiveUntil', 'tonAdsWatchedDaily', 'lastTonAdReset', 'gramBalance', 'gramMiningRate', 'lastGramSync', 'gramMiningActiveUntil', 'withdrawals'])
          && incoming().balance >= existing().balance
        )
        ||
        // Action: buy upgrade (balance decreases, profitPerHour increases)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'profitPerHour', 'upgrades', 'tonBalance', 'tonMiningRate', 'lastTonSync', 'tonMiningActiveUntil', 'gramBalance', 'gramMiningRate', 'lastGramSync', 'gramMiningActiveUntil', 'withdrawals'])
          && incoming().balance <= existing().balance
        )
        ||
        // Action: Claim Task
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'missions', 'tonBalance', 'gramBalance'])
          && incoming().balance >= existing().balance
        )
        || 
        // Action: Ads / Referrals
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'adsWatched', 'friendsCount', 'tonBalance', 'tonMiningRate', 'tonMiningActiveUntil'])
          && incoming().balance >= existing().balance
        )
        ||
        // Action: Wallet / Withdrawing
        (
           incoming().diff(existing()).affectedKeys().hasOnly(['walletAddress', 'withdrawals', 'tonBalance'])
        )
      )) 
      || isAdmin();
    }
    
    // Referrals (Managed entirely by Cloudflare Worker via Admin SDK)
    match /referrals/{referralId} {
       allow read: if isSignedIn() && (isOwner(referralId) || resource.data.referrerId == request.auth.uid || resource.data.referrerTelegramId == request.auth.uid);
       allow write: if false; // Only manageable via Cloudflare Worker
    }
  }
}
