rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isAdmin() {
      // Allow if they are in the admins collection (console added)
      // or if their role is admin
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // User Schema Validation
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'username', 'balance', 'energy', 'maxEnergy', 'profitPerHour', 'lastLogin']) 
        && data.balance is number 
        && data.energy is number 
        && data.maxEnergy is number 
        && data.profitPerHour is number 
        && data.lastLogin is number;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());

      // Update rules (Anti-Cheat logic)
      allow update: if (isOwner(userId) && isValidUser(incoming()) && (
        // Action: standard sync (balance increases, energy decreases/regenerates)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'energy', 'lastLogin', 'offlineEarnings', 'friendsCount', 'adsWatched', 'referredBy', 'referralRewardClaimed', 'upgrades', 'missions'])
          && incoming().balance >= existing().balance
        )
        ||
        // Action: buy upgrade (balance decreases, profitPerHour increases)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'profitPerHour', 'upgrades'])
          && incoming().balance < existing().balance
          && incoming().profitPerHour >= existing().profitPerHour
        )
        ||
        // Action: Claim Task
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'missions'])
          && incoming().balance >= existing().balance
        )
        || 
        // Action: Ads / Referrals
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'adsWatched', 'friendsCount'])
          && incoming().balance >= existing().balance
        )
        ||
        // Action: Wallet
        (
           incoming().diff(existing()).affectedKeys().hasOnly(['walletAddress'])
        )
      )) 
      || isAdmin()
      || (
         // Atomic transactions from NEW user
         isSignedIn() &&
         incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'friendsCount']) &&
         incoming().balance == existing().balance + 100000 &&
         incoming().friendsCount == existing().friendsCount + 1 &&
         existsAfter(/databases/$(database)/documents/referrals/$(request.auth.uid)) &&
         getAfter(/databases/$(database)/documents/referrals/$(request.auth.uid)).data.referrerId == userId
      );
    }
    
    // Referrals
    match /referrals/{referralId} {
       allow read: if isSignedIn();
       allow create: if isSignedIn() && incoming().keys().hasAll(['userId', 'referrerId']);
    }
  }
}
