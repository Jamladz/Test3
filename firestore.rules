rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isAdmin() {
      // Allow if they are in the admins collection (console added)
      // or if their role is admin
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // User Schema Validation
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'balance', 'energy', 'lastLogin']) 
        && data.balance is number 
        && data.energy is number 
        && data.lastLogin is number;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());

      // Update rules (Anti-Cheat logic)
      allow update: if (isOwner(userId) && isValidUser(incoming()) && (
        (incoming().role == existing().role || (!('role' in existing()) && incoming().role == 'user')) &&
        incoming().diff(existing()).affectedKeys().hasOnly([
            'balance', 'energy', 'lastLogin', 'offlineEarnings', 'friendsCount', 'adsWatched', 
            'referredBy', 'referralRewardClaimed', 'upgrades', 'missions', 'totalTapped', 'gifts', 
            'createdAt', 'tonBalance', 'tonMiningRate', 'lastTonSync', 'tonMiningActiveUntil', 
            'tonAdsWatchedDaily', 'lastTonAdReset', 'gramBalance', 'gramMiningRate', 'lastGramSync', 
            'gramMiningActiveUntil', 'withdrawals', 'hasClaimedPlushAirdrop', 'profitPerHour', 'walletAddress', 'role'
        ])
      )) 
      || isAdmin();
    }
    
    // Referrals (Managed entirely by Cloudflare Worker via Admin SDK)
    match /referrals/{referralId} {
       allow read: if isSignedIn() && (isOwner(referralId) || resource.data.referrerId == request.auth.uid || resource.data.referrerTelegramId == request.auth.uid);
       allow write: if false; // Only manageable via Cloudflare Worker
    }
  }
}
